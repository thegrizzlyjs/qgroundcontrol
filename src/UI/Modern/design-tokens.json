{
  "version": "1.0.0",
  "metadata": {
    "name": "QGroundControl Modern UI Design System",
    "description": "Design tokens for the modernized QGC interface",
    "author": "QGC Team",
    "created": "2026-06-17"
  },
  "colors": {
    "primary": {
      "cyan": "#00BCD4",
      "cyan_light": "#4DD0E1",
      "cyan_dark": "#0097A7",
      "emerald": "#10B981",
      "emerald_light": "#34D399",
      "emerald_dark": "#059669"
    },
    "neutral": {
      "white": "#FFFFFF",
      "gray_50": "#F9FAFB",
      "gray_100": "#F3F4F6",
      "gray_200": "#E5E7EB",
      "gray_300": "#D1D5DB",
      "gray_400": "#9CA3AF",
      "gray_500": "#6B7280",
      "gray_600": "#4B5563",
      "gray_700": "#374151",
      "gray_800": "#1F2937",
      "gray_900": "#111827",
      "black": "#000000"
    },
    "semantic": {
      "success": "#10B981",
      "warning": "#F59E0B",
      "error": "#EF4444",
      "info": "#3B82F6",
      "disabled": "#9CA3AF"
    },
    "dark_mode": {
      "bg_primary": "#111827",
      "bg_secondary": "#1F2937",
      "bg_tertiary": "#374151",
      "text_primary": "#F9FAFB",
      "text_secondary": "#D1D5DB",
      "text_tertiary": "#9CA3AF",
      "border": "#4B5563"
    },
    "light_mode": {
      "bg_primary": "#FFFFFF",
      "bg_secondary": "#F9FAFB",
      "bg_tertiary": "#F3F4F6",
      "text_primary": "#111827",
      "text_secondary": "#4B5563",
      "text_tertiary": "#9CA3AF",
      "border": "#D1D5DB"
    },
    "high_contrast": {
      "text": "#000000",
      "bg": "#FFFFFF",
      "focus": "#0000FF"
    }
  },
  "typography": {
    "family": {
      "sans": "Inter Variable",
      "mono": "JetBrains Mono",
      "fallback": "system-ui"
    },
    "sizes": {
      "xs": 12,
      "sm": 14,
      "base": 16,
      "lg": 18,
      "xl": 20,
      "2xl": 24,
      "3xl": 30,
      "4xl": 36
    },
    "weights": {
      "light": 300,
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "extrabold": 800
    },
    "lineheight": {
      "tight": 1.2,
      "normal": 1.5,
      "relaxed": 1.75,
      "loose": 2.0
    },
    "scales": {
      "h1": {
        "size": 36,
        "weight": 700,
        "lineheight": 1.2,
        "letterspacing": -0.5
      },
      "h2": {
        "size": 30,
        "weight": 700,
        "lineheight": 1.25,
        "letterspacing": -0.3
      },
      "h3": {
        "size": 24,
        "weight": 600,
        "lineheight": 1.35,
        "letterspacing": 0
      },
      "body_lg": {
        "size": 16,
        "weight": 400,
        "lineheight": 1.5,
        "letterspacing": 0
      },
      "body_base": {
        "size": 14,
        "weight": 400,
        "lineheight": 1.5,
        "letterspacing": 0
      },
      "body_sm": {
        "size": 12,
        "weight": 400,
        "lineheight": 1.5,
        "letterspacing": 0
      },
      "caption": {
        "size": 11,
        "weight": 500,
        "lineheight": 1.4,
        "letterspacing": 0.5
      }
    }
  },
  "spacing": {
    "0": 0,
    "0_5": 2,
    "1": 4,
    "1_5": 6,
    "2": 8,
    "2_5": 10,
    "3": 12,
    "3_5": 14,
    "4": 16,
    "5": 20,
    "6": 24,
    "7": 28,
    "8": 32,
    "9": 36,
    "10": 40,
    "12": 48,
    "14": 56,
    "16": 64,
    "20": 80,
    "24": 96,
    "28": 112,
    "32": 128,
    "36": 144,
    "40": 160,
    "44": 176,
    "48": 192,
    "52": 208,
    "56": 224,
    "60": 240,
    "64": 256
  },
  "radii": {
    "none": 0,
    "sm": 2,
    "base": 4,
    "md": 6,
    "lg": 8,
    "xl": 12,
    "2xl": 16,
    "3xl": 24,
    "full": 9999
  },
  "shadows": {
    "none": "none",
    "xs": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
    "sm": "0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06)",
    "base": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06)",
    "md": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05)",
    "lg": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04)",
    "xl": "0 25px 50px -12px rgba(0, 0, 0, 0.25)",
    "2xl": "0 25px 50px -12px rgba(0, 0, 0, 0.25)",
    "inner": "inset 0 2px 4px 0 rgba(0, 0, 0, 0.05)"
  },
  "animations": {
    "durations": {
      "fast": 150,
      "base": 200,
      "slow": 300,
      "slower": 500
    },
    "timings": {
      "linear": "linear",
      "ease_in": "ease-in",
      "ease_out": "ease-out",
      "ease_in_out": "ease-in-out",
      "ease_quad": "cubic-bezier(0.25, 0.46, 0.45, 0.94)",
      "ease_cubic": "cubic-bezier(0.25, 0.1, 0.25, 1)"
    }
  },
  "breakpoints": {
    "mobile": 320,
    "tablet": 768,
    "desktop": 1024,
    "wide": 1280,
    "ultrawide": 1536
  },
  "touchTargets": {
    "min": 44,
    "preferred": 48,
    "compact": 36
  },
  "accessibility": {
    "focusRing": {
      "width": 2,
      "color": "#3B82F6",
      "offset": 2
    },
    "minContrast": "AA",
    "reduceMotion": true
  }
}
